{
  "name": "@dev-bb/eslint-plugin-alias-extensions",
  "version": "0.1.9",
  "description": "ESLint plugin to enforce file extensions for alias imports",
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs",
  "imports": {
    "#src/*": "./src/*"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vitest watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "npm run build && eslint .",
    "lint:fast": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepublishOnly": "npm run typecheck && npm run build && npm test",
    "release:patch": "npm version patch --no-git-tag-version && git add package.json package-lock.json && npx pubv --yes patch",
    "release:minor": "npm version minor --no-git-tag-version && git add package.json package-lock.json && npx pubv --yes minor",
    "release:major": "npm version major --no-git-tag-version && git add package.json package-lock.json && npx pubv --yes major"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0"
  },
  "optionalDependencies": {
    "@emnapi/core": "1.10.0",
    "@emnapi/runtime": "1.10.0"
  },
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=20.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@microsoft/api-extractor": "^7.58.9",
    "@runwisp/pubv": "^1.3.0",
    "@types/node": "^26.0.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@typescript-eslint/utils": "^8.61.0",
    "eslint": "^10.0.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.0.0"
  },
  "author": "dev-bb",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BibbyChung/eslint-plugin-alias-extensions.git"
  },
  "bugs": {
    "url": "https://github.com/BibbyChung/eslint-plugin-alias-extensions/issues"
  },
  "homepage": "https://github.com/BibbyChung/eslint-plugin-alias-extensions#readme",
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "alias-extensions",
    "import",
    "extension",
    "alias",
    "file-extension",
    "subpath",
    "typescript",
    "flat-config"
  ],
  "license": "MIT"
}
